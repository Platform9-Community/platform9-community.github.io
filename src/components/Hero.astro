---
import SearchBar from './SearchBar.astro';
---

<section
  class="relative w-full overflow-hidden"
  style="background: linear-gradient(135deg, #0A0F2E 0%, #0D1A6B 55%, #1B4FD8 100%)"
>
  <div class="max-w-[1280px] mx-auto px-6 py-20 flex items-center gap-12">
    <!-- Left: headline + CTAs -->
    <div class="flex-1 min-w-0">
      <h1 class="text-4xl lg:text-5xl font-bold text-white leading-tight max-w-xl">
        Community projects and applications for Platform9 Private Cloud Director
      </h1>
      <p class="mt-4 text-lg text-white/70 max-w-lg leading-relaxed">
        Discover, share, and collaborate on solutions that extend the power of Platform9 Private Cloud Director.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="/projects"
          class="inline-flex items-center px-6 py-3 bg-brand-blue text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-blue-light"
        >
          Explore Projects
        </a>
        <a
          href="/contribute"
          class="inline-flex items-center px-6 py-3 border-2 border-white/60 text-white font-semibold rounded-lg hover:bg-white/10 transition-colors"
        >
          Contribute Your Project
        </a>
      </div>
    </div>

    <!-- Right: tech illustration -->
    <div class="hidden lg:block flex-shrink-0 w-80 xl:w-96" aria-hidden="true">
      <svg viewBox="0 0 380 320" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Platform9 PCD infrastructure illustration">
        <!-- Cloud shape -->
        <ellipse cx="210" cy="70" rx="60" ry="30" fill="#1B6FE8" opacity="0.25"/>
        <ellipse cx="245" cy="65" rx="45" ry="25" fill="#1B6FE8" opacity="0.3"/>
        <ellipse cx="175" cy="72" rx="40" ry="22" fill="#1B6FE8" opacity="0.25"/>
        <rect x="150" y="68" width="140" height="40" rx="4" fill="#1B6FE8" opacity="0.2"/>
        <!-- Cloud outline -->
        <ellipse cx="212" cy="68" rx="60" ry="28" stroke="#4B9EFF" stroke-width="1.5" opacity="0.6"/>
        <ellipse cx="247" cy="62" rx="44" ry="22" stroke="#4B9EFF" stroke-width="1.5" opacity="0.5"/>
        <ellipse cx="178" cy="70" rx="38" ry="20" stroke="#4B9EFF" stroke-width="1.5" opacity="0.5"/>

        <!-- Server panel -->
        <rect x="100" y="115" width="180" height="130" rx="6" fill="#0D1A6B" stroke="#1B6FE8" stroke-width="1.5" opacity="0.9"/>
        <!-- Server rows -->
        <rect x="112" y="128" width="156" height="20" rx="3" fill="#1B6FE8" opacity="0.15"/>
        <rect x="112" y="128" width="156" height="20" rx="3" stroke="#1B6FE8" stroke-width="1" opacity="0.4"/>
        <rect x="120" y="133" width="60" height="10" rx="2" fill="#4B9EFF" opacity="0.3"/>
        <circle cx="252" cy="138" r="4" fill="#16A34A" opacity="0.8"/>

        <rect x="112" y="155" width="156" height="20" rx="3" fill="#1B6FE8" opacity="0.15"/>
        <rect x="112" y="155" width="156" height="20" rx="3" stroke="#1B6FE8" stroke-width="1" opacity="0.4"/>
        <rect x="120" y="160" width="80" height="10" rx="2" fill="#4B9EFF" opacity="0.3"/>
        <circle cx="252" cy="165" r="4" fill="#16A34A" opacity="0.8"/>

        <rect x="112" y="182" width="156" height="20" rx="3" fill="#1B6FE8" opacity="0.15"/>
        <rect x="112" y="182" width="156" height="20" rx="3" stroke="#1B6FE8" stroke-width="1" opacity="0.4"/>
        <rect x="120" y="187" width="45" height="10" rx="2" fill="#4B9EFF" opacity="0.3"/>
        <circle cx="252" cy="192" r="4" fill="#D97706" opacity="0.8"/>

        <rect x="112" y="209" width="156" height="20" rx="3" fill="#1B6FE8" opacity="0.15"/>
        <rect x="112" y="209" width="156" height="20" rx="3" stroke="#1B6FE8" stroke-width="1" opacity="0.4"/>
        <rect x="120" y="214" width="70" height="10" rx="2" fill="#4B9EFF" opacity="0.3"/>
        <circle cx="252" cy="219" r="4" fill="#16A34A" opacity="0.8"/>

        <!-- Connecting line cloud to server -->
        <line x1="205" y1="95" x2="195" y2="115" stroke="#4B9EFF" stroke-width="1.5" stroke-dasharray="4 3" opacity="0.6"/>
        <circle cx="205" cy="104" r="3" fill="#4B9EFF" opacity="0.8"/>

        <!-- Isometric cube -->
        <g transform="translate(255, 195)">
          <!-- Top face -->
          <polygon points="40,0 80,20 40,40 0,20" fill="#1B6FE8" opacity="0.9"/>
          <!-- Left face -->
          <polygon points="0,20 40,40 40,80 0,60" fill="#0D1A6B" opacity="0.9" stroke="#1B6FE8" stroke-width="1"/>
          <!-- Right face -->
          <polygon points="40,40 80,20 80,60 40,80" fill="#2563EB" opacity="0.7" stroke="#4B9EFF" stroke-width="1"/>
          <!-- Top edge highlight -->
          <polygon points="40,0 80,20 40,40 0,20" fill="none" stroke="#4B9EFF" stroke-width="1.5" opacity="0.8"/>
        </g>

        <!-- Decorative dots -->
        <circle cx="85" cy="160" r="2.5" fill="#4B9EFF" opacity="0.5"/>
        <circle cx="75" cy="185" r="2" fill="#4B9EFF" opacity="0.4"/>
        <circle cx="88" cy="205" r="1.5" fill="#4B9EFF" opacity="0.3"/>
        <circle cx="320" cy="130" r="2.5" fill="#4B9EFF" opacity="0.5"/>
        <circle cx="330" cy="155" r="2" fill="#4B9EFF" opacity="0.4"/>
      </svg>
    </div>
  </div>

  <!-- Search bar — overlaps section boundary -->
  <div class="relative z-10 max-w-[1280px] mx-auto px-6 pb-0">
    <div class="max-w-2xl -mb-6">
      <SearchBar />
    </div>
  </div>
  <!-- Bottom padding to account for overlapping search bar -->
  <div class="h-10"></div>
</section>
